generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model appointments {
  id                   Int                  @id @default(autoincrement())
  business_id          Int
  service_id           Int
  client_name          String               @db.VarChar(100)
  client_email         String?              @db.VarChar(150)
  client_phone         String?              @db.VarChar(20)
  appointment_datetime DateTime             @db.DateTime(0)
  status               appointments_status? @default(pending)
  source               appointments_source? @default(web)
  otp_token            String?              @db.VarChar(10)
  token_expires_at     DateTime?            @db.DateTime(0)
  created_at           DateTime?            @default(now()) @db.Timestamp(0)
  updated_at           DateTime?            @default(now()) @db.Timestamp(0)
  businesses           businesses           @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "appointments_ibfk_1")
  services             services             @relation(fields: [service_id], references: [id], onUpdate: NoAction, map: "appointments_ibfk_2")
  reviews              reviews?

  @@index([business_id, appointment_datetime], map: "idx_appointment_time")
  @@index([client_email], map: "idx_client_email")
  @@index([service_id], map: "service_id")
}

model business_categories {
  id         Int          @id @default(autoincrement())
  name       String       @db.VarChar(50)
  businesses businesses[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model business_hours {
  id          Int        @id @default(autoincrement())
  business_id Int
  day_of_week Int        @db.TinyInt
  open_time   DateTime   @db.Time(0)
  close_time  DateTime   @db.Time(0)
  is_closed   Boolean?   @default(false)
  businesses  businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "business_hours_ibfk_1")

  @@unique([business_id, day_of_week], map: "unique_business_day")
}

model businesses {
  id                  Int                 @id @default(autoincrement())
  user_id             Int
  category_id         Int
  name                String              @db.VarChar(150)
  slug                String              @unique(map: "slug") @db.VarChar(150)
  address             String?             @db.VarChar(255)
  phone               String              @db.VarChar(20)
  is_whatsapp         Boolean?            @default(false)
  logo_url            String?             @db.VarChar(255)
  theme_palette       String?             @default("classic_light") @db.VarChar(50)
  policies            String?             @db.Text
  created_at          DateTime?           @default(now()) @db.Timestamp(0)
  updated_at          DateTime?           @default(now()) @db.Timestamp(0)
  appointments        appointments[]
  business_hours      business_hours[]
  users               users               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "businesses_ibfk_1")
  business_categories business_categories @relation(fields: [category_id], references: [id], onUpdate: NoAction, map: "businesses_ibfk_2")
  services            services[]

  @@index([category_id], map: "idx_category")
  @@index([user_id], map: "user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reviews {
  id             Int          @id @default(autoincrement())
  appointment_id Int          @unique(map: "appointment_id")
  rating         Int          @db.TinyInt
  created_at     DateTime?    @default(now()) @db.Timestamp(0)
  appointments   appointments @relation(fields: [appointment_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "reviews_ibfk_1")
}

model services {
  id               Int            @id @default(autoincrement())
  business_id      Int
  name             String         @db.VarChar(100)
  duration_minutes Int
  buffer_minutes   Int?           @default(0)
  price_display    String?        @db.VarChar(50)
  appointments     appointments[]
  businesses       businesses     @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "services_ibfk_1")

  @@index([business_id], map: "idx_business_services")
}

model users {
  id            Int          @id @default(autoincrement())
  name          String       @db.VarChar(100)
  email         String       @unique(map: "email") @db.VarChar(150)
  password_hash String       @db.VarChar(255)
  reset_token   String?      @db.VarChar(255)
  created_at    DateTime?    @default(now()) @db.Timestamp(0)
  updated_at    DateTime?    @default(now()) @db.Timestamp(0)
  businesses    businesses[]
}

enum appointments_status {
  pending
  approved
  completed
  cancelled
}

enum appointments_source {
  web
  manual
}
